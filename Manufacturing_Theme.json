{
  "name": "Manufacturing Industrial Blue-Gray",
  "dataColors": [
    "#1F3864",
    "#2E75B6",
    "#8FAADC",
    "#748DA6",
    "#41729F",
    "#5D8AA8",
    "#A9B7C6",
    "#C62828",
    "#F9A825",
    "#2E7D32"
  ],
  "background": "#FFFFFF",
  "foreground": "#1A1A1A",
  "tableAccent": "#1F3864",
  "good": "#2E7D32",
  "neutral": "#F9A825",
  "bad": "#C62828",
  "maximum": "#1F3864",
  "center": "#8FAADC",
  "minimum": "#EAEEF4",
  "null": "#B0B0B0",
  "textClasses": {
    "callout": { "fontSize": 32, "fontFace": "Segoe UI Semibold", "color": "#1F3864" },
    "title": { "fontSize": 14, "fontFace": "Segoe UI Semibold", "color": "#1F3864" },
    "header": { "fontSize": 12, "fontFace": "Segoe UI Semibold", "color": "#333333" },
    "label": { "fontSize": 10, "fontFace": "Segoe UI", "color": "#333333" }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [{ "show": true, "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 0 }],
        "border": [{ "show": true, "color": { "solid": { "color": "#E1E5EA" } }, "radius": 6 }],
        "outspacePane": [{ "backgroundColor": { "solid": { "color": "#F4F6F8" } } }],
        "title": [{
          "show": true,
          "fontColor": { "solid": { "color": "#1F3864" } },
          "fontSize": 13,
          "fontFamily": "Segoe UI Semibold",
          "background": { "solid": { "color": "#FFFFFF" } }
        }]
      }
    },
    "card": {
      "*": {
        "labels": [{ "color": { "solid": { "color": "#1F3864" } }, "fontSize": 28 }],
        "categoryLabels": [{ "color": { "solid": { "color": "#5A5A5A" } }, "fontSize": 11 }]
      }
    },
    "multiRowCard": {
      "*": {
        "card": [{ "outlineColor": { "solid": { "color": "#E1E5EA" } } }]
      }
    },
    "page": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#F4F6F8" } }, "transparency": 0 }]
      }
    },
    "slicer": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#FFFFFF" } } }],
        "items": [{ "fontColor": { "solid": { "color": "#333333" } }, "background": { "solid": { "color": "#FFFFFF" } } }]
      }
    }
  }
}
